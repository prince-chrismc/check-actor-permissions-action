{
  "name": "check-actor-permissions-action",
  "description": "GitHub Action to check if an actor has a specific access to the repository",
  "version": "4.0.0",
  "author": "Christopher McArthur <prince.chrismc@gmail.com>",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/prince-chrismc/check-actor-permissions-action#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prince-chrismc/check-actor-permissions-action.git"
  },
  "bugs": {
    "url": "https://github.com/prince-chrismc/check-actor-permissions-action/issues"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "eslint --fix src/**/*.ts && eslint --fix __tests__/**/*.ts",
    "local-action": "npx @github/local-action . src/main.ts .env",
    "package": "npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "test": "NODE_NO_WARNINGS=1 NODE_OPTIONS=--experimental-vm-modules npx jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@github/local-action": "^7.0.1",
    "@jest/globals": "^30.4.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "nock": "^15.0.0-beta.12",
    "prettier": "^3.8.1",
    "prettier-plugin-ignored": "^1.0.0",
    "rollup": "^4.57.1",
    "ts-jest": "^29.4.11",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
